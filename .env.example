# ─── Frontend (.env) ───────────────────────────────────────────────────────
# Copy this file to .env and fill in the values

VITE_GOOGLE_CLIENT_ID=        # Your Google OAuth client ID
VITE_GA4_PROPERTY_ID=         # (Optional) Default GA4 property ID
VITE_GSC_SITE_URL=            # (Optional) Default Google Search Console site URL
VITE_AHREFS_API_KEY=          # Your Ahrefs API key


# ─── Backend (server/.env) ─────────────────────────────────────────────────
# Create server/.env separately with the following:

# GOOGLE_CLIENT_ID=           # Same as VITE_GOOGLE_CLIENT_ID above
# GOOGLE_CLIENT_SECRET=       # Your Google OAuth client secret
# REDIRECT_URI=http://localhost:5173/auth/callback
# JWT_SECRET=                 # A random 32+ character secret string
# ALLOWED_DOMAIN=             # (Optional) Restrict login to one email domain e.g. "example.com"
#                             # Leave blank to allow any Google account
# AHREFS_EXTRA_PROJECT_IDS=   # (Optional) Comma-separated Ahrefs project IDs not in default listing
# FRONTEND_URL=http://localhost:5173
